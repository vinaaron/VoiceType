# Voice CLI Environment Variables
# Copy this to .env and fill in your values
# .env is gitignored - safe for secrets

# Groq API key (for fast cloud transcription and LLM refinement)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Override config file location
# VOICE_CLI_CONFIG=~/.voice-cli/config.yaml
