    <key>NSMicrophoneUsageDescription</key>
    <string>VoiceCLI listens to your microphone for voice-to-text dictation. The daemon spawned by this app records audio when you press Ctrl+Opt+V.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>VoiceCLI sends keystrokes to paste the transcribed text into the app you were typing into.</string>
</dict>
