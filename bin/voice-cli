#!/usr/bin/env python3
"""
Voice CLI - Voice-to-text for Claude Code terminal sessions (one-shot mode).

This is the fallback / direct-invocation entrypoint. The fast path goes
through bin/voice-cli-client → src/daemon.py (which keeps models warm).
This script is what runs when the daemon is unreachable.

Second press of the hotkey while a recording is in progress sends SIGUSR1
to the running instance, which stops recording immediately and transcribes
whatever was captured so far.
"""

import argparse
import atexit
import os
import signal
import subprocess
import sys
import threading

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
SRC_DIR = os.path.join(os.path.dirname(SCRIPT_DIR), "src")
sys.path.insert(0, SRC_DIR)

try:
    from dotenv import load_dotenv
    for env_path in [
        os.path.join(os.path.dirname(SCRIPT_DIR), ".env"),
        os.path.expanduser("~/.voice-cli/.env"),
    ]:
        if os.path.exists(env_path):
            load_dotenv(env_path)
            break
except ImportError:
    pass

from logger import get_logger, log_stage, log_info, log_error
from session import run_voice_session

PID_FILE = os.path.expanduser("~/.voice-cli/voice-cli.pid")

stop_requested = threading.Event()


def _handle_stop_signal(signum, frame):
    stop_requested.set()


def write_pidfile() -> None:
    os.makedirs(os.path.dirname(PID_FILE), exist_ok=True)
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))


def remove_pidfile() -> None:
    try:
        if os.path.exists(PID_FILE):
            with open(PID_FILE) as f:
                pid = int(f.read().strip() or "0")
            if pid == os.getpid():
                os.remove(PID_FILE)
    except (OSError, ValueError):
        pass


def signal_running_instance_or_claim() -> bool:
    if not os.path.exists(PID_FILE):
        write_pidfile()
        return False

    try:
        with open(PID_FILE) as f:
            other_pid = int(f.read().strip() or "0")
    except (OSError, ValueError):
        other_pid = 0

    if other_pid <= 0 or other_pid == os.getpid():
        try:
            os.remove(PID_FILE)
        except OSError:
            pass
        write_pidfile()
        return False

    try:
        os.kill(other_pid, 0)
    except ProcessLookupError:
        log_info(f"clearing stale pidfile pid={other_pid}")
        try:
            os.remove(PID_FILE)
        except OSError:
            pass
        write_pidfile()
        return False
    except PermissionError:
        pass

    try:
        os.kill(other_pid, signal.SIGUSR1)
        log_info(f"toggle: sent SIGUSR1 to running instance pid={other_pid}")
    except OSError as e:
        log_error(f"failed to signal running instance pid={other_pid}: {e}")
    return True


def load_config():
    import json
    config_dir = os.path.expanduser("~/.voice-cli")
    yaml_path = os.path.join(config_dir, "config.yaml")
    json_path = os.path.join(config_dir, "config.json")

    defaults = {
        "model": "distil-medium.en",
        "transcription_mode": "moonshine",
        "groq_api_key": None,
        "silence_duration": 1.2,
        "silence_threshold": "1%",
        "sound_feedback": True,
        "convert_numbers": True,
        "show_notifications": True,
        "vad_mode": True,
        "vad_threshold": 0.5,
        "max_duration": 300,
        "duration": 5.0,
        "auto_enter": True,
        "enter_triggers": ["enter", "send", "submit", "return"],
        "llm_refinement": True,
        "llm_backend": "groq",
        "llm_model": "llama-3.3-70b-versatile",
        "ollama_url": "http://localhost:11434",
        "llm_triggers": None,
        "daemon_mlx_idle_minutes": 30,
    }

    if os.path.exists(yaml_path):
        try:
            import yaml
            with open(yaml_path) as f:
                user_config = yaml.safe_load(f) or {}
            defaults.update(user_config)
            return defaults
        except Exception:
            pass

    if os.path.exists(json_path):
        try:
            with open(json_path) as f:
                user_config = json.load(f) or {}
            defaults.update(user_config)
        except Exception:
            pass

    return defaults


def main():
    parser = argparse.ArgumentParser(description="Voice-to-text for terminal sessions")
    parser.add_argument("--no-sound", action="store_true")
    parser.add_argument("--no-numbers", action="store_true")
    parser.add_argument("--model", default=None)
    parser.add_argument("--mode", default=None, choices=["moonshine", "parakeet", "groq", "local"])
    parser.add_argument("--duration", type=float, default=5.0)
    parser.add_argument("--no-vad", action="store_true")
    parser.add_argument("--silence", type=float, default=None)
    parser.add_argument("--vad-threshold", type=float, default=None)
    parser.add_argument("--debug", action="store_true")
    parser.add_argument("--no-notify", action="store_true")
    parser.add_argument("--no-enter", action="store_true")
    parser.add_argument("--no-llm", action="store_true")
    args = parser.parse_args()

    get_logger(debug=args.debug)
    log_stage("start")

    config = load_config()
    # CLI overrides
    if args.model: config["model"] = args.model
    if args.mode: config["transcription_mode"] = args.mode
    if args.duration: config["duration"] = args.duration
    if args.silence is not None: config["silence_duration"] = args.silence
    if args.vad_threshold is not None: config["vad_threshold"] = args.vad_threshold
    if args.no_sound: config["sound_feedback"] = False
    if args.no_numbers: config["convert_numbers"] = False
    if args.no_notify: config["show_notifications"] = False
    if args.no_vad: config["vad_mode"] = False
    if args.no_enter: config["auto_enter"] = False
    if args.no_llm: config["llm_refinement"] = False

    if signal_running_instance_or_claim():
        return

    atexit.register(remove_pidfile)
    signal.signal(signal.SIGUSR1, _handle_stop_signal)

    try:
        run_voice_session(config, stop_requested, debug=args.debug)
    except KeyboardInterrupt:
        log_info("cancelled (KeyboardInterrupt)")
        sys.exit(0)
    except FileNotFoundError as e:
        if config.get("show_notifications", True):
            from output import notify
            notify("Voice CLI Error", str(e))
        log_error(f"FileNotFoundError: {e}")
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        if config.get("show_notifications", True):
            from output import notify
            notify("Voice CLI Error", str(e)[:100])
        log_error(f"unhandled exception: {e}")
        print(f"Error: {e}", file=sys.stderr)
        if args.debug:
            import traceback
            traceback.print_exc()
        sys.exit(1)
    finally:
        remove_pidfile()


if __name__ == "__main__":
    main()
